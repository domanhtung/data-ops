{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "data-ops",
    "main": ".open-next/worker.js",
    "compatibility_date": "2026-03-24",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "assets": {
        "directory": ".open-next/assets"
    },
    "observability": {
        "enabled": true
    }
}